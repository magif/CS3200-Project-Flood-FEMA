import pandas as pd
import matplotlib.pyplot as plt
import seaborn as sns
import numpy as np


# Load the data
file_path = 'DataEX/WITH_ZipYearAgg_AS__SELECT_clean_zip___.csv'
df = pd.read_csv(file_path)

# Ensure proper numeric types and clean up
df.columns = df.columns.str.strip()

# Calculate the ultimate normalized metric: Total Payout per 100 Policies
# This tells us the actual financial burn rate for a neighborhood, removing population bias.
df['Payout per 100 Policies'] = df['Claims per 100 Policies'] * df['Average Payout (2020 Dollars)']

# 1. Heatmap: Normalized Payout Risk
pivot_norm = df.pivot(index='Percent Impervious Surface', columns='Year', values='Payout per 100 Policies')
pivot_norm = pivot_norm.sort_index(ascending=False) # Put 100% at the top

plt.figure(figsize=(16, 8))
ax = sns.heatmap(pivot_norm, cmap='YlOrRd', linewidths=0.5, 
                 cbar_kws={'label': 'Payout per 100 Policies ($2020)'})
plt.title('Normalized Financial Risk: Payouts per 100 Policies', fontsize=16, fontweight='bold')
plt.ylabel('Percent Impervious Surface (%)', fontsize=12)
plt.xlabel('Year', fontsize=12)

# Format colorbar to currency
cbar = ax.collections[0].colorbar
cbar.ax.yaxis.set_major_formatter(plt.matplotlib.ticker.StrMethodFormatter('${x:,.0f}'))

plt.tight_layout()
plt.savefig('heatmap_normalized.png')
plt.close()

# 2. Heatmap: Average Payout (Severity of individual claims)
pivot_avg = df.pivot(index='Percent Impervious Surface', columns='Year', values='Average Payout (2020 Dollars)')
pivot_avg = pivot_avg.sort_index(ascending=False)

plt.figure(figsize=(16, 8))
ax2 = sns.heatmap(pivot_avg, cmap='flare', linewidths=0.5, 
                  cbar_kws={'label': 'Average Payout ($2020)'})
plt.title('Claim Severity: Average Payout per Claim', fontsize=16, fontweight='bold')
plt.ylabel('Percent Impervious Surface (%)', fontsize=12)
plt.xlabel('Year', fontsize=12)

cbar2 = ax2.collections[0].colorbar
cbar2.ax.yaxis.set_major_formatter(plt.matplotlib.ticker.StrMethodFormatter('${x:,.0f}'))

plt.tight_layout()
plt.savefig('heatmap_avg.png')
plt.close()

print("Heatmaps generated successfully.")