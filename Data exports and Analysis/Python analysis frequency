import pandas as pd
import matplotlib.pyplot as plt
import seaborn as sns


# Load the data
file_path = 'DataEX/WITH_ZipYearAgg_AS__SELECT_clean_zip___.csv'
df = pd.read_csv(file_path)





# Ensure proper numeric types and clean up
df.columns = df.columns.str.strip()

# 1. Total Payouts by Impervious Surface
plt.figure(figsize=(10, 6))
sns.barplot(data=df, x='Percent Impervious Surface', y='Total Payouts (2020 Dollars)', estimator=sum, errorbar=None, color='#3498db')
plt.title('Total Historical Payouts by Impervious Surface Level', fontsize=14, fontweight='bold')
plt.ylabel('Total Payouts (2020 Dollars)', fontsize=12)
plt.xlabel('Percent Impervious Surface (%)', fontsize=12)
plt.gca().yaxis.set_major_formatter(plt.matplotlib.ticker.StrMethodFormatter('${x:,.0f}'))
plt.tight_layout()
plt.savefig('payouts_by_surface.png')
plt.close()

# 2. Scatter / Reg plot: Normalized Claims vs Impervious Surface
plt.figure(figsize=(10, 6))
sns.regplot(data=df, x='Percent Impervious Surface', y='Claims per 100 Policies', 
            scatter_kws={'alpha':0.4, 'color': '#2ecc71'}, line_kws={'color': '#e74c3c'})
plt.title('Correlation: Impervious Surface vs. Claim Frequency', fontsize=14, fontweight='bold')
plt.ylabel('Claims per 100 Policies', fontsize=12)
plt.xlabel('Percent Impervious Surface (%)', fontsize=12)
plt.tight_layout()
plt.savefig('claims_vs_surface.png')
plt.close()

# 3. Time Series: Claim frequency over time grouped by Impervious Surface
df['Surface_Bin'] = pd.cut(df['Percent Impervious Surface'], 
                           bins=[-1, 33, 66, 100], 
                           labels=['Low (0-33%)', 'Medium (34-66%)', 'High (67-100%)'])

plt.figure(figsize=(12, 6))
sns.lineplot(data=df, x='Year', y='Claims per 100 Policies', hue='Surface_Bin', estimator='mean', errorbar=None, palette='magma')
plt.title('Claim Frequency Trends Over Time by Development Level', fontsize=14, fontweight='bold')
plt.ylabel('Average Claims per 100 Policies', fontsize=12)
plt.xlabel('Year', fontsize=12)
plt.legend(title='Impervious Surface')
plt.tight_layout()
plt.savefig('trend_over_time.png')
plt.close()

print(df.describe())